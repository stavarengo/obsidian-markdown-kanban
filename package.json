{
  "name": "folia-kanban",
  "version": "0.0.1",
  "packageManager": "pnpm@11.3.0",
  "description": "A real Kanban board for Obsidian, with Markdown files as the source of truth.",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "build:updateExamplesVault": "OUT_DIR=examples/.obsidian/plugins/folia-kanban node esbuild.config.mjs production",
    "release:bump-plugin-version": "node scripts/bump-plugin-version.mjs",
    "ci:release": "release-it --ci",
    "dev:helpers:release": "release-it",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "tokens:check": "node scripts/check-tokens.mjs",
    "audit:raw-values": "node scripts/audit-raw-values.mjs",
    "waivers:check": "node scripts/check-waivers.mjs",
    "ds:check": "pnpm tokens:check && pnpm audit:raw-values && pnpm waivers:check && pnpm lint:a11y && pnpm test:a11y && pnpm test:visual",
    "lint:a11y": "eslint src",
    "test:a11y": "vitest run test/a11y.axe.test.tsx",
    "test:visual": "vitest run test/visual-regression.test.tsx",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "js-yaml": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "axe-core": "^4.12.1",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.23.1",
    "eslint": "^10.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "lefthook": "^2.1.9",
    "obsidian": "^1.7.2",
    "release-it": "19.2.2",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.61.1",
    "vitest": "^2.1.1",
    "vitest-axe": "^0.1.0"
  }
}
