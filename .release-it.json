{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "git": {
    "requireCleanWorkingDir": false,
    "requireBranch": "main",
    "requireUpstream": true,
    "requireCommits": true,
    "addUntrackedFiles": false,
    "commit": true,
    "commitMessage": "chore(release): ${version} :rocket:",
    "tag": true,
    "tagName": "${version}",
    "tagAnnotation": "Release ${version}",
    "push": true
  },
  "hooks": {
    "after:bump": "pnpm release:bump-plugin-version ${tagName}"
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false,
    "ignoreVersion": true,
    "allowSameVersion": true
  }
}
