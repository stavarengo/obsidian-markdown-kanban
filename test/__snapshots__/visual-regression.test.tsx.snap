exports[`structural visual-regression snapshots > a column header keeps its structural shape (.folia-column-header) 1`] = `"<header class="folia-column-header"><span class="folia-column-dot" aria-hidden="true"></span><span class="folia-column-title" title="Drag to reorder, click to rename" role="button" tabindex="0" aria-disabled="false" aria-roledescription="sortable">Todo</span><span class="folia-column-count" role="img" title="1 cards" aria-label="1 cards">1</span><button class="folia-icon-btn folia-column-menu-btn" aria-label="Column options for Todo" aria-haspopup="dialog" aria-expanded="false"><svg class="folia-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="1"></circle><circle cx="19" cy="12" r="1"></circle><circle cx="5" cy="12" r="1"></circle></svg></button></header>"`;

exports[`structural visual-regression snapshots > a rendered card keeps its structural shape (.folia-card) 1`] = `"<div class="folia-card" data-testid="card" data-path="Tasks/Alpha.md" data-prio="prio-1" style="transition: transform 0ms linear;"><div class="folia-card-main" role="button" tabindex="0" aria-disabled="false" aria-roledescription="sortable" aria-label="Alpha"><div class="folia-card-title">Alpha</div><div class="folia-chips"><span class="folia-chip folia-chip-prio-1" title="Priority">A</span><span class="folia-chip folia-chip-muted" title="Tag">home</span></div><div class="folia-progress" title="1 of 2 subtasks done" aria-label="1 of 2 subtasks done"><div class="folia-progress-track"><div class="folia-progress-fill" style="width: 50%;"></div></div><span class="folia-progress-label">1/2</span></div><div class="folia-card-meta"><span title="Comments" aria-label="1 comment"><svg class="folia-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg> 1</span></div></div><div class="folia-card-actions"><button class="folia-icon-btn folia-action-done" aria-label="Mark &quot;Alpha&quot; done" title="Mark done"><svg class="folia-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M21.5 11.5a9.5 9.5 0 1 1-5.6-8.2"></path><path d="m9 11 3 3L22 4"></path></svg></button><button class="folia-icon-btn" aria-label="Open note for &quot;Alpha&quot;" title="Open note"><svg class="folia-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg></button><button class="folia-icon-btn folia-action-delete" aria-label="Delete &quot;Alpha&quot;" title="Delete card"><svg class="folia-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M3 6h18"></path><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><path d="M10 11v6M14 11v6"></path></svg></button></div></div>"`;
