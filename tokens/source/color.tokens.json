{
  "$description": "Semantic colors, priority/status palette, and the column product palette. Live semantic/priority tokens byte-match the --folia-* block in src/styles.css; the column palette mirrors the 8 hexes exported by src/ui/columnColors.ts (COLUMN_COLORS). Obsidian var() references are preserved verbatim as strings.",
  "color": {
    "primitive": {
      "$description": "Theme-backed color primitives. Each preserves Obsidian's var(--theme, fallback) string exactly. Semantic and palette tokens reference these where they share a source.",
      "red": { "$value": "var(--color-red, #e5534b)", "$type": "color" },
      "orange": { "$value": "var(--color-orange, #d9882f)", "$type": "color" },
      "yellow": { "$value": "var(--color-yellow, #c2a312)", "$type": "color" },
      "blue": { "$value": "var(--color-blue, #5b8def)", "$type": "color" },
      "green": { "$value": "var(--color-green, #4caf7d)", "$type": "color" }
    },
    "border": {
      "$value": "var(--background-modifier-border)",
      "$type": "color",
      "$extensions": { "folia": { "cssVar": "--folia-border", "live": true } }
    },
    "border-strong": {
      "$value": "var(--background-modifier-border-hover, var(--background-modifier-border))",
      "$type": "color",
      "$extensions": { "folia": { "cssVar": "--folia-border-strong", "live": true } }
    },
    "card-bg": {
      "$value": "var(--background-primary)",
      "$type": "color",
      "$extensions": { "folia": { "cssVar": "--folia-card-bg", "live": true } }
    },
    "col-bg": {
      "$value": "var(--background-secondary)",
      "$type": "color",
      "$extensions": { "folia": { "cssVar": "--folia-col-bg", "live": true } }
    },
    "accent": {
      "$value": "var(--interactive-accent)",
      "$type": "color",
      "$extensions": { "folia": { "cssVar": "--folia-accent", "live": true } }
    },
    "on-accent": {
      "$value": "var(--text-on-accent, #fff)",
      "$type": "color",
      "$extensions": { "folia": { "cssVar": "--folia-on-accent", "live": true } }
    },
    "danger": {
      "$value": "{color.primitive.red}",
      "$type": "color",
      "$extensions": { "folia": { "cssVar": "--folia-danger", "live": true, "resolvedValue": "var(--color-red, #e5534b)" } }
    },
    "success": {
      "$value": "{color.primitive.green}",
      "$type": "color",
      "$extensions": { "folia": { "cssVar": "--folia-success", "live": true, "resolvedValue": "var(--color-green, #4caf7d)" } }
    },
    "scrim": {
      "$description": "Modal/side-panel backdrop. NEW token home — appears raw at styles.css:1071 and :1487; no --folia-* var defined yet (CSS adoption pending).",
      "$value": "rgba(0, 0, 0, 0.45)",
      "$type": "color",
      "$extensions": { "folia": { "cssVar": "--folia-scrim", "live": false } }
    },
    "priority": {
      "$description": "Priority ramp urgent->trivial, tinted off the theme's accent palette. Live --folia-prio-* tokens.",
      "1": {
        "$value": "{color.primitive.red}",
        "$type": "color",
        "$extensions": { "folia": { "cssVar": "--folia-prio-1", "live": true, "resolvedValue": "var(--color-red, #e5534b)" } }
      },
      "2": {
        "$value": "{color.primitive.orange}",
        "$type": "color",
        "$extensions": { "folia": { "cssVar": "--folia-prio-2", "live": true, "resolvedValue": "var(--color-orange, #d9882f)" } }
      },
      "3": {
        "$value": "{color.primitive.yellow}",
        "$type": "color",
        "$extensions": { "folia": { "cssVar": "--folia-prio-3", "live": true, "resolvedValue": "var(--color-yellow, #c2a312)" } }
      },
      "4": {
        "$value": "{color.primitive.blue}",
        "$type": "color",
        "$extensions": { "folia": { "cssVar": "--folia-prio-4", "live": true, "resolvedValue": "var(--color-blue, #5b8def)" } }
      }
    },
    "column": {
      "$description": "Product palette for user-assignable column accent colors. NOT theme-backed and NOT the priority ramp. Single JS source of truth is src/ui/columnColors.ts (exported as COLUMN_COLORS), imported by ColumnEditModal.tsx, ColumnMenu.tsx, and Column.tsx. Checked against that JS source, not against styles.css.",
      "1": { "$value": "#4c9aff", "$type": "color" },
      "2": { "$value": "#8fd14f", "$type": "color" },
      "3": { "$value": "#ffab00", "$type": "color" },
      "4": { "$value": "#9c8cff", "$type": "color" },
      "5": { "$value": "#ff5c5c", "$type": "color" },
      "6": { "$value": "#57d9a3", "$type": "color" },
      "7": { "$value": "#f78fb3", "$type": "color" },
      "8": { "$value": "#9aa0a6", "$type": "color" }
    }
  }
}
