{
  "$description": "NEW category. Captures the z-index ladder currently raw in src/styles.css (values 1, 2, 30, 50, 55, 60, 70, 80, 90) as a named scale by stacking role. No --folia-* z-index vars exist yet (CSS adoption pending); these tokens are the new home, not a byte-match of the .folia-root block.",
  "z-index": {
    "$type": "number",
    "base": { "$value": "1", "$extensions": { "folia": { "live": false } } },
    "raised": { "$value": "2", "$extensions": { "folia": { "live": false } } },
    "sticky": { "$value": "30", "$extensions": { "folia": { "live": false } } },
    "toast": { "$value": "50", "$extensions": { "folia": { "live": false } } },
    "scrim": { "$value": "55", "$extensions": { "folia": { "live": false } } },
    "menu": { "$value": "60", "$extensions": { "folia": { "live": false } } },
    "popover": { "$value": "70", "$extensions": { "folia": { "live": false } } },
    "modal": { "$value": "80", "$extensions": { "folia": { "live": false } } },
    "top": { "$value": "90", "$extensions": { "folia": { "live": false } } }
  }
}
